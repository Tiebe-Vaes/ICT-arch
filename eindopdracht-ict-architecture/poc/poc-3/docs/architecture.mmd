    classDef app fill:#eef2ff,stroke:#4f46e5,stroke-width:2px,color:#111827;
    classDef module fill:#f5f3ff,stroke:#7c3aed,stroke-width:2px,color:#111827;
    classDef broker fill:#ecfdf5,stroke:#16a34a,stroke-width:2px,color:#111827;
    classDef queue fill:#fff7ed,stroke:#f97316,stroke-width:2px,color:#111827;
    classDef failure fill:#fef2f2,stroke:#dc2626,stroke-width:2px,color:#111827;

    class Tester,Dashboard actor;
    class API,NotificationWorker,AuditWorker app;
    class Trip module;
    class Events,RetryExchange,DeadExchange broker;
    class NotificationQueue,AuditQueue,RetryQueue queue;
    class DeadQueue failure;
