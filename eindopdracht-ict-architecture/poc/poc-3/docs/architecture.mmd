%%{init: {"theme": "base", "themeVariables": {"fontFamily": "Inter, Segoe UI, Arial", "primaryTextColor": "#172033", "lineColor": "#64748b", "mainBkg": "#ffffff", "clusterBkg": "#f8fafc", "clusterBorder": "#cbd5e1"}}}%%
flowchart LR
    Tester([Tester / PowerShell])

    subgraph Stack[Docker Swarm stack: poc3]
        direction LR

        subgraph App[Shared Node.js app image]
            direction TB
            API["trip-api<br/>Express API<br/><b>synchronous command</b>"]
            Trip["Trip module<br/>tripService.js<br/>create invitation + event"]
            NotificationWorker["notification-worker<br/>prefetch: 1<br/>retry + DLQ"]
            AuditWorker["audit-worker<br/>prefetch: 10<br/>audit log"]
        end

        subgraph Rabbit[RabbitMQ broker]
            direction TB
            Events{{"travelapp.events<br/>topic exchange"}}
            NotificationQueue[("notification.trip-events<br/>queue")]
            AuditQueue[("audit.events<br/>queue")]
            RetryExchange{{"travelapp.retry<br/>direct exchange"}}
            RetryQueue[("notification.retry<br/>TTL 5s")]
            DeadExchange{{"travelapp.dead-letter<br/>topic exchange"}}
            DeadQueue[("notification.dead-letter<br/>queue")]
        end
    end

    Dashboard([RabbitMQ dashboard<br/>localhost:15672])

    Tester -->|HTTP POST invitation| API
    API -->|calls| Trip
    Trip -->|invitation + TripMemberInvited| API
    API -->|publish routing key<br/>trip.member.invited| Events

    Events -->|binding: trip.member.invited| NotificationQueue
    Events -->|binding: #| AuditQueue
    NotificationQueue --> NotificationWorker
    AuditQueue --> AuditWorker

    NotificationWorker -.->|failure: notification.retry| RetryExchange
    RetryExchange --> RetryQueue
    RetryQueue -.->|after TTL: back to events| Events
    NotificationWorker -.->|after 3 retries| DeadExchange
    DeadExchange --> DeadQueue

    Tester -.-> Dashboard
    Dashboard -.-> Rabbit

